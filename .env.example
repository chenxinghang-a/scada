# SCADA System Environment Variables
# Copy to .env and fill in values for production

# Security (REQUIRED for production)
SECRET_KEY=
JWT_SECRET=

# Database
SCADA_DB_PATH=data/scada.db

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# PA Broadcast
PA_BROKER=localhost
PA_MQTT_PORT=1883

# TDengine (optional)
TDENGINE_HOST=localhost
TDENGINE_PORT=6041
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=scada

# Application
SCADA_MODE=simulated
SCADA_HOST=0.0.0.0
SCADA_PORT=5000
DEBUG=false

# Logging (structured JSON for SIEM integration)
SCADA_LOG_DIR=logs
SCADA_LOG_LEVEL=INFO
SCADA_LOG_JSON=true
SCADA_LOG_ROTATION=100 MB
SCADA_LOG_RETENTION=30 days
