{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "设备在线状态",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "tdengine-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as total_devices FROM scada.devices",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "title": "当前报警数",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "tdengine-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) as active_alarms FROM scada.alarms WHERE status='active'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "OEE 综合效率",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "tdengine-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT LAST(oee_value) as oee FROM scada.oee_data",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "实时数据趋势",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "tdengine-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT ts, temperature, pressure FROM scada.device_data WHERE ts > NOW() - 1h ORDER BY ts",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "title": "报警历史",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "tdengine-datasource", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT ts, device_id, alarm_level, alarm_message FROM scada.alarms ORDER BY ts DESC LIMIT 50",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["scada", "industrial"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "SCADA 系统总览",
  "uid": "scada-overview",
  "version": 1
}
